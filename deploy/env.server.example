# Copy to /opt/dermeee/.env on the VPS (never commit real secrets).
# Compose reads this file from the same directory as docker-compose.prod.yml.

# Registry (backend CI updates API_IMAGE_TAG; frontend CI or manual updates FRONTEND_IMAGE_TAG)
DOCKER_REGISTRY=ghcr.io/your-org
API_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

POSTGRES_USER=dermee_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dermee_db

API_PORT=3000
FRONTEND_PORT=3001

JWT_SECRET=
REFRESH_SECRET=
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# OAuth — match backend ConfigService keys (see auth/strategies/*.strategy.ts)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback
# OAUTH_FACEBOOK_APP_ID=
# OAUTH_FACEBOOK_APP_SECRET=
# OAUTH_FACEBOOK_CALLBACK_URL=https://api.yourdomain.com/auth/facebook/callback
# OAUTH_SUCCESS_REDIRECT=https://yourdomain.com/auth/callback
